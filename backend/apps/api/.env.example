# SmartCart API — environment (README §2.9). Copy to `.env` for local dev.
NODE_ENV=development
PORT=3000

# Postgres (matches backend/infra/docker/docker-compose.yml)
DATABASE_URL="postgresql://smartcart:smartcart@localhost:5432/smartcart?schema=public"

# JWT auth (access + refresh, README §2.5). Use long random strings in real envs.
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# QR signing secret — MUST be >= 32 chars (README §2.3 QR rules).
QR_SIGNING_SECRET="dev-qr-signing-secret-min-32-chars-long!!"

# POS API key (plaintext). Seed stores its SHA-256 hash in the ApiKey table.
POS_API_KEY="pos-demo-key-0001"
# B2B analytics API key (plaintext). Seeded as SHA-256 hash.
B2B_API_KEY="b2b-demo-key-0001"

# CORS — Expo dev client / Metro
CORS_ORIGIN="*"
