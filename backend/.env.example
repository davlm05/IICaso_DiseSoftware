# SmartCart backend — environment template (README §2.5 / §2.9).
# Copy to `.env` and fill real values. NEVER commit a populated `.env`.

NODE_ENV=development
PORT=3000

# ── Database (README §2.4 / §2.7) ──────────────────────────────────────────────
# In production point this at PgBouncer (port 6432) with sslmode=require.
DATABASE_URL="postgresql://smartcart:smartcart@localhost:5432/smartcart?schema=public"
PRISMA_CONNECTION_LIMIT=10

# ── Redis (cache / sessions / rate-limit / BullMQ) ─────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT auth (README §2.5 — secrets MUST be >= 32 chars) ───────────────────────
JWT_ACCESS_SECRET="dev-access-secret-change-me-min-32-chars!!"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me-min-32-chars!"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# ── QR signing (README §2.3 — secret MUST be >= 32 chars) ──────────────────────
QR_SIGNING_SECRET="dev-qr-signing-secret-min-32-chars-long!!"

# ── API keys (POS / B2B). Seed stores the SHA-256 hash in the ApiKey table. ────
POS_API_KEY="pos-demo-key-0001"
B2B_API_KEY="b2b-demo-key-0001"

# ── Rate limiting (README §2.5) ────────────────────────────────────────────────
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# ── CORS (Expo dev client / Metro) ─────────────────────────────────────────────
CORS_ORIGIN="*"

# ── Observability (README §2.6 — optional; absence disables the exporter) ──────
# Leave unset (commented) unless you have real endpoints: the API validates
# these as URLs, so an EMPTY value fails env validation at boot.
# SENTRY_DSN=
# OTEL_EXPORTER_OTLP_ENDPOINT=
APP_VERSION="0.0.0"

# ── Analytics worker (README §2.5 A10 — AI_INFERENCE_URL must be HTTPS) ─────────
AI_INFERENCE_URL="https://ai-inference.smartcart.app"
AI_REQUEST_TIMEOUT_MS=5000
