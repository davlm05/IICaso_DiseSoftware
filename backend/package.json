{
  "name": "@smartcart/backend",
  "version": "1.0.0",
  "description": "SmartCart backend — NestJS modular monolith (apps/api) + standalone analytics worker (apps/analytics-worker). README §2.",
  "license": "UNLICENSED",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev": "nest start --watch --path apps/api/tsconfig.json",
    "build": "pnpm -r --filter \"./packages/*\" build && nest build api && nest build analytics-worker",
    "start": "node --require ./apps/api/dist/tracing.js apps/api/dist/main.js",
    "start:worker": "node apps/analytics-worker/dist/main.js",
    "lint": "eslint \"apps/**/*.ts\" --max-warnings=0",
    "format": "prettier --write \"apps/**/*.ts\"",
    "format:check": "prettier --check \"apps/**/*.ts\"",
    "type-check": "tsc -p apps/api/tsconfig.json --noEmit && tsc -p apps/analytics-worker/tsconfig.json --noEmit",
    "test:unit": "jest --config apps/api/jest.unit.config.ts",
    "test:integration": "jest --config apps/api/jest.integration.config.ts",
    "test:contract": "jest --config apps/api/jest.unit.config.ts --selectProjects contract",
    "prisma:migrate": "prisma migrate dev --schema apps/api/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema apps/api/prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema apps/api/prisma/schema.prisma",
    "openapi:generate": "ts-node apps/api/src/openapi/generate.ts",
    "openapi:validate": "vacuum lint docs/api/openapi.yaml",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down"
  },
  "dependencies": {
    "@nestjs/bullmq": "10.2.1",
    "@nestjs/common": "10.4.4",
    "@nestjs/config": "3.2.3",
    "@nestjs/core": "10.4.4",
    "@nestjs/platform-express": "10.4.4",
    "@nestjs/platform-socket.io": "10.4.4",
    "@nestjs/schedule": "4.1.1",
    "@nestjs/swagger": "7.4.2",
    "@nestjs/terminus": "10.2.3",
    "@nestjs/websockets": "10.4.4",
    "@ntegral/nestjs-sentry": "4.0.1",
    "@opentelemetry/auto-instrumentations-node": "0.50.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.53.0",
    "@opentelemetry/sdk-node": "0.53.0",
    "@prisma/client": "5.20.0",
    "@sentry/node": "8.33.1",
    "@smartcart/shared-types": "workspace:*",
    "@willsoto/nestjs-prometheus": "6.0.1",
    "axios": "1.7.7",
    "bcrypt": "5.1.1",
    "bullmq": "5.18.0",
    "helmet": "8.0.0",
    "ioredis": "5.4.1",
    "jsonwebtoken": "9.0.2",
    "nestjs-pino": "4.1.0",
    "pino": "9.4.0",
    "pino-http": "10.3.0",
    "prom-client": "15.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "socket.io": "4.8.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.5",
    "@nestjs/testing": "10.4.4",
    "@types/bcrypt": "5.0.2",
    "@types/jest": "29.5.13",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "20.16.11",
    "@types/supertest": "6.0.2",
    "eslint": "9.12.0",
    "jest": "29.7.0",
    "prettier": "3.3.3",
    "prisma": "5.20.0",
    "supertest": "7.0.0",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "typescript": "5.5.4",
    "typescript-eslint": "8.8.1"
  }
}
