# SmartCart AI dev platform — root environment template.
# Copy to `.env` and fill in real values:  cp .env.example .env
#
# (The backend stack reads its own env from backend/.env — also copy that:
#  cp backend/.env.example backend/.env)

# ── Claude auth (the AI agents need ONE of the options below) ──────────────────
# Option A — metered API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Option B — reuse your Claude subscription (no key). Easiest with Claude Code:
#     claude setup-token            # prints a long-lived token (sk-ant-oat...)
#   then either run `source platform/scripts/use-claude-auth.sh`, or set:
# AIDEV_AUTH_MODE=oauth
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...   # paste your token (in .env, NOT here)
#   (ANTHROPIC_AUTH_TOKEN also works; `ant auth login` is an alternative if you
#    have the Anthropic CLI installed.)
#
# AIDEV_AUTH_MODE: oauth (default — API key wins, else OAuth) | api-key | oauth

# Model selection (optional overrides; sensible defaults are built in).
AIDEV_MODEL=claude-opus-4-8
AIDEV_MODEL_LIGHT=claude-haiku-4-5-20251001

# Max tool-use iterations per agent before it must submit a result.
AIDEV_MAX_ITERATIONS=24

# ── GitHub (optional — enables /release-feature to open a PR) ───────────────────
# A token with `repo` scope, or run `gh auth login` inside the orchestrator.
GH_TOKEN=

# ── Offline mode (optional) ────────────────────────────────────────────────────
# Set to 1 to run the deterministic, no-API-key scaffold strategy (great for a
# dry run or grading without credentials).
AIDEV_OFFLINE=0
