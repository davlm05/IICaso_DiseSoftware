# Variables de entorno del frontend (Vite expone solo las que empiezan con VITE_).
# En la Fase 2 la app usa servicios mock; estas variables se activan en la Fase 3
# cuando se conecte el backend real.

# URL base de la API de SmartCart (backend, Fase 3).
VITE_API_BASE_URL=https://api.smartcart.cr

# Origen permitido / entorno.
VITE_APP_ENV=development
