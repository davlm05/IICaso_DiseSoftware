{
  "expo": {
    "name": "SmartCart",
    "slug": "smartcart-frontend",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "smartcart",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.smartcart.app"
    },
    "android": {
      "package": "com.smartcart.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "SmartCart usa la cámara para escanear productos."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SmartCart usa tu ubicación para ofertas cercanas."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
